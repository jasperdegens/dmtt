# DMTT environment template — copy to `.env.local` and fill in.
# `.env` / `.env*.local` are gitignored. NEVER commit real secrets into THIS file.
# Server-only secrets (plaintext, K, Ledger key, World signing_key) must NEVER be NEXT_PUBLIC_*.

# ── Hedera (operator = the agent authority; pays for all ops) ──────────────
# Needed by spikes S2 (schedule) and S3 (HFS). Get a funded TESTNET account
# from https://portal.hedera.com/ (faucet). Per the pre-kickoff checklist:
# operator + 2 spare accounts funded.
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.xxxxxxx
# Private key (raw hex, or DER starting 302e.../3030...). Server-only secret.
HEDERA_OPERATOR_KEY=
# ECDSA | ED25519 — disambiguates a raw-hex key (testnet faucet accounts are ECDSA).
HEDERA_KEY_TYPE=ECDSA

# Public mirror node REST base (no key required). Default if unset:
#   testnet -> https://testnet.mirrornode.hedera.com
HEDERA_MIRROR_URL=https://testnet.mirrornode.hedera.com
# Optional: pin a specific tx id for the S4 mirror spike (e.g. S1's Ledger transfer).
# Format: {payer}-{validStartSecs}-{nanos}, e.g. 0.0.1234-1700000000-000000000
HEDERA_MIRROR_TX_ID=

# ── World ID 4.0 (authorizes check-ins; never delegated) ───────────────────
# Needed by spike S6. Create the app/RP/action + capture the one-time
# signing_key via the Developer Portal MCP (https://developer.world.org/api/mcp).
WORLD_APP_ID=app_xxxxxxxx
WORLD_RP_ID=
WORLD_ACTION=check-in
# Returned exactly once at app creation. Server-only secret. NEVER NEXT_PUBLIC_*.
WORLD_SIGNING_KEY=
# staging | production — must match the IDKit `environment` and Simulator-vs-App.
WORLD_ENV=staging
NEXT_PUBLIC_WORLD_APP_ID=app_xxxxxxxx

# ── Anthropic (watcher LLM bulletin + chat) ────────────────────────────────
ANTHROPIC_API_KEY=
