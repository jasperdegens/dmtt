# DMTT environment template — copy to `.env.local` and fill in.
# `.env` / `.env*.local` are gitignored. NEVER commit real secrets into THIS file.
# Server-only secrets (plaintext, K, Ledger key, World signing_key) must NEVER be NEXT_PUBLIC_*.

# ── Hedera (operator = the agent authority; pays for all ops) ──────────────
# Needed by spikes S2 (schedule) and S3 (HFS). Get a funded TESTNET account
# from https://portal.hedera.com/ (faucet). Per the pre-kickoff checklist:
# operator + 2 spare accounts funded.
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.xxxxxxx
# Public browser-side config for Ledger WebHID signing. Account id only, no key.
NEXT_PUBLIC_HEDERA_NETWORK=testnet
NEXT_PUBLIC_HEDERA_OPERATOR_ID=0.0.xxxxxxx
# Optional public mirror override; defaults from NEXT_PUBLIC_HEDERA_NETWORK.
# NEXT_PUBLIC_HEDERA_MIRROR_URL=https://testnet.mirrornode.hedera.com
# Private key (raw hex, or DER starting 302e.../3030...). Server-only secret.
HEDERA_OPERATOR_KEY=
# ECDSA | ED25519 — disambiguates a raw-hex key (testnet faucet accounts are ECDSA).
HEDERA_KEY_TYPE=ECDSA

# Public mirror node REST base (no key required). Default if unset:
#   testnet -> https://testnet.mirrornode.hedera.com
HEDERA_MIRROR_URL=https://testnet.mirrornode.hedera.com
# Optional: pin a specific tx id for the S4 mirror spike (e.g. S1's Ledger transfer).
# Format: {payer}-{validStartSecs}-{nanos}, e.g. 0.0.1234-1700000000-000000000
HEDERA_MIRROR_TX_ID=

# ── World ID 4.0 (authorizes check-ins; never delegated) ───────────────────
# Needed by spike S6. Create the app/RP/action + capture the one-time
# signing_key via the Developer Portal MCP (https://developer.world.org/api/mcp).
WORLD_APP_ID=app_xxxxxxxx
WORLD_RP_ID=
WORLD_ACTION=check-in
# Returned exactly once at app creation. Server-only secret. NEVER NEXT_PUBLIC_*.
WORLD_SIGNING_KEY=
# staging | production — must match the IDKit `environment` and Simulator-vs-App.
WORLD_ENV=staging
NEXT_PUBLIC_WORLD_APP_ID=app_xxxxxxxx
# Client-side World config (the switch-action check-in card reads these). Mirror
# WORLD_ACTION / WORLD_ENV. Public by design (no secret here).
NEXT_PUBLIC_WORLD_ACTION=check-in
NEXT_PUBLIC_WORLD_ENV=staging

# ── Anthropic (watcher LLM bulletin + chat) ────────────────────────────────
ANTHROPIC_API_KEY=

# ── Executor verification flags (Phase 5: real artifacts) ──────────────────
# Default ON. Set a flag to "false" ONLY for local mock/dev runs:
#   DMTT_VERIFY_ARM     mirror-verify the ARM transfer (SUCCESS + memo + Ledger debit + funding ≥ terms.fundingHbar)
#   DMTT_VERIFY_CHECKIN World-verify the check-in proof + re-enforce signal + nullifier
#   DMTT_VERIFY_CANCEL  mirror-verify the CANCEL transfer (SUCCESS + memo + Ledger debit)
# DMTT_VERIFY_ARM=false
# DMTT_VERIFY_CHECKIN=false
# DMTT_VERIFY_CANCEL=false
# Optional per-check-in agent "service fee" payment + SERVICE_FEE_PAID event (off by default).
# DMTT_SERVICE_FEE=true

# ── Watcher (release reaction + cancel backstop) ───────────────────────────
# Release-bounty payout: the agent pays this account (defaults to the switch owner)
# DMTT_BOUNTY_HBAR ℏ (defaults to 5% of funding, clamped to [0.01, 1]) at release.
# DMTT_BOUNTY_ACCOUNT_ID=0.0.xxxxxxx
# DMTT_BOUNTY_HBAR=0.5
# Cancel backstop: scans the agent account's inbound txs for device-signed
# DMTT:CANCEL:<topicId> memos and honors them even without a /api/cancel call.
# On by default; set "false" to disable.
# DMTT_CANCEL_BACKSTOP=false
